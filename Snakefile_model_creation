import sys
from pathlib import Path

# Shared helpers live in blueearth_cst/; make them importable regardless of the working
# directory by prepending this Snakefile's own directory to sys.path.
# See dev/r03/model-builder-design.md §3.
sys.path.insert(0, str(Path(workflow.basedir)))
from blueearth_cst.shared.snake_utils import get_config, patch_psutil_windows_benchmark, rule_banner

# Windows: make Snakemake's benchmark memory/IO/CPU metrics work (else all NA).
patch_psutil_windows_benchmark()

# read path of the config file (Snakemake records it from --configfile) so
# downstream R scripts can be handed the same path. Forwarding config_path is
# a repo convention — keep it even though the Snakefile itself uses `config`.
config_path = workflow.configfiles[0]

# Portable tee wrapper for the shell rules below: keeps live console output AND
# preserves the child's exit code (a bare `| tee` masks failures on cmd.exe --
# no pipefail there). See blueearth_cst/shared/run_logged.py / blueearth_cst.shared.snake_utils.run_and_tee.
run_logged = str(Path(workflow.basedir) / "blueearth_cst" / "shared" / "run_logged.py")

# R01 schema — three top-level sections. Read each into a local dict.
project_cfg = config["project"]
shared_cfg = config["shared"]
my_cfg = config["workflows"]["model_creation"]

# Project — paths and external resources
project_dir = get_config(project_cfg, "project_dir", optional=False)
static_dir = get_config(project_cfg, "static_dir", optional=False)
DATA_SOURCES = get_config(project_cfg, "data_sources", optional=False)

# Shared — multi-workflow scientific knobs
model_region = get_config(shared_cfg["basin"], "region", optional=False)
model_resolution = get_config(shared_cfg["basin"], "resolution", 0.00833333)
clim_source = get_config(shared_cfg, "clim_historical", optional=False)
hist_starttime = get_config(shared_cfg["historical_window"], "starttime", optional=False)
hist_endtime = get_config(shared_cfg["historical_window"], "endtime", optional=False)

# P3-2a bounded support (design ext2-3): the wf1 raw-climate path (rule 1.10 +
# the model-parity plot re-source) supports era5, chirps and chirps_global
# only. eobs fails here at DAG-parse time — before any rule executes — so the
# rejection is early and loud on every run and dry-run.
if clim_source == "eobs":
    raise ValueError(
        "clim_historical: eobs is not supported by the P3-2a wf1 raw-climate "
        "path; supported sources: era5, chirps, chirps_global"
    )

# Workflow-owned
wflow_outvars = get_config(my_cfg, "wflow_outvars", ['river discharge', 'actual evapotranspiration'])
model_build_config = get_config(my_cfg, "model_build_config", f"{static_dir}/templates/wflow_build_model.yml")
waterbodies_config = get_config(my_cfg, "waterbodies_config", f"{static_dir}/templates/wflow_update_waterbodies.yml")
output_locations = get_config(my_cfg, "output_locations", None)
observations_timeseries = get_config(my_cfg, "observations_timeseries", None)

basin_dir = f"{project_dir}/hydrology_model"

# Rule numbering (comment headers + log/benchmark filenames) uses `W.NN` =
# workflow.step in DEFINITION order — a reading and reference aid ("Rule 1.3" =
# create_model), NOT guaranteed execution order. Snakemake resolves execution
# from the DAG: e.g. 1.10-1.12 are parallel plot leaves, not a sequence. All
# three workflows share project_dir/logs, so the leading digit keeps them
# disambiguated and globally sortable. Convention: dev/conventions/naming.md.

# 1.00  all — target aggregator: full historical build + performance plots
rule all:
    input: 
        f"{project_dir}/plots/wflow_model_performance/hydro_wflow_1.png",
        f"{project_dir}/plots/wflow_model_performance/basin_area.png",
        f"{project_dir}/plots/wflow_model_performance/precip.png",
        f"{project_dir}/config/snake_config_model_creation.yml",
        f"{basin_dir}/staticgeoms/outlet_index.csv",
        f"{project_dir}/benchmarks/wf1_benchmarks.md",

# 1.01  copy_config — copy build/snake/waterbodies configs into project_dir/config
rule copy_config:
    message: rule_banner("1.01", "copy_config")
    input:
        config_build = model_build_config,
        config_snake = config_path,
        config_waterbodies = waterbodies_config,
    params:
        data_catalogs = DATA_SOURCES,
        workflow_name = "model_creation",
    output:
        config_snake_out = f"{project_dir}/config/snake_config_model_creation.yml",
    script:
        "blueearth_cst/model/copy_config_files.py"

# 1.02  prepare_build_config — merge snake-config values (model_resolution) into
# the build config. hydromt 1.3 dropped `--opt`, so we generate a runtime config.
rule prepare_build_config:
    message: rule_banner("1.02", "prepare_build_config")
    input:
        template = model_build_config,
    output:
        merged = f"{project_dir}/config/wflow_build_model_run.yml",
    params:
        model_resolution = model_resolution,
        model_region = model_region,
    log:
        f"{project_dir}/logs/1.02_prepare_build_config.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/1.02_prepare_build_config.tsv",
    script:
        "blueearth_cst/model/prepare_build_config.py"

# 1.03  create_model — build the Wflow-SBM model (hydromt build wflow_sbm)
rule create_model:
    message: rule_banner("1.03", "create_model")
    input:
        hydromt_ini = f"{project_dir}/config/wflow_build_model_run.yml",
    output:
        basin_nc = f"{basin_dir}/staticmaps.nc",
    log:
        f"{project_dir}/logs/1.03_create_model.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/1.03_create_model.tsv",
    shell:
        """python -u "{run_logged}" "{log}" -- hydromt build wflow_sbm "{basin_dir}" -i "{input.hydromt_ini}" -d "{DATA_SOURCES}" --fo -vv"""

# 1.04  add_reservoirs_lakes_glaciers — add waterbodies to the built model
# (temporary hydromt fix; can fold back into create_model when hydromt is updated)
rule add_reservoirs_lakes_glaciers:
    message: rule_banner("1.04", "add_reservoirs_lakes_glaciers")
    input:
        basin_nc = ancient(f"{basin_dir}/staticmaps.nc")
    output:
        text_out = f"{basin_dir}/staticgeoms/reservoirs_lakes_glaciers.txt"
    params:
        data_catalog = DATA_SOURCES,
        config = waterbodies_config,
    log:
        f"{project_dir}/logs/1.04_add_reservoirs_lakes_glaciers.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/1.04_add_reservoirs_lakes_glaciers.tsv",
    script:
        "blueearth_cst/model/setup_reservoirs_lakes_glaciers.py"

# 1.05  add_gauges_and_outputs — add gauges + output variables to the model
rule add_gauges_and_outputs:
    message: rule_banner("1.05", "add_gauges_and_outputs")
    input:
        basin_nc = ancient(f"{basin_dir}/staticmaps.nc"),
        text = f"{basin_dir}/staticgeoms/reservoirs_lakes_glaciers.txt"
    output:
        gauges_path = f"{basin_dir}/staticgeoms/outlets.geojson"
    params:
        output_locs = output_locations,
        outputs = wflow_outvars,
        data_catalog = DATA_SOURCES
    log:
        f"{project_dir}/logs/1.05_add_gauges_and_outputs.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/1.05_add_gauges_and_outputs.tsv",
    script:
        "blueearth_cst/model/setup_gauges_and_outputs.py"

# 1.06  write_outlet_index — write the outlet position -> subcatchment-ID mapping
rule write_outlet_index:
    message: rule_banner("1.06", "write_outlet_index")
    input:
        outlets_path = f"{basin_dir}/staticgeoms/outlets.geojson"
    output:
        outlet_index_path = f"{basin_dir}/staticgeoms/outlet_index.csv"
    log:
        f"{project_dir}/logs/1.06_write_outlet_index.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/1.06_write_outlet_index.tsv",
    script:
        "blueearth_cst/model/write_outlet_index.py"

# 1.07  setup_runtime — prepare the forcing time horizon / runtime window
rule setup_runtime:
    message: rule_banner("1.07", "setup_runtime")
    input:
        gauges_path = f"{basin_dir}/staticgeoms/outlets.geojson"
    output:
        forcing_yml = f"{project_dir}/config/wflow_build_forcing_historical.yml"
    params:
        starttime = get_config(shared_cfg["historical_window"], "starttime", optional=False),
        endtime = get_config(shared_cfg["historical_window"], "endtime", optional=False),
        clim_source = get_config(shared_cfg, "clim_historical", optional=False),
        basin_dir = basin_dir,
    log:
        f"{project_dir}/logs/1.07_setup_runtime.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/1.07_setup_runtime.tsv",
    script: "blueearth_cst/shared/setup_time_horizon.py"

# 1.08  add_forcing — add historical forcing to the model (hydromt update wflow_sbm)
rule add_forcing:
    message: rule_banner("1.08", "add_forcing")
    input:
        forcing_ini = f"{project_dir}/config/wflow_build_forcing_historical.yml"
    output:
        forcing_path = f"{project_dir}/climate_historical/wflow_data/inmaps_historical.nc"
    log:
        f"{project_dir}/logs/1.08_add_forcing.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/1.08_add_forcing.tsv",
    shell:
        """python -u "{run_logged}" "{log}" -- hydromt update wflow_sbm "{basin_dir}" -i "{input.forcing_ini}" -d "{DATA_SOURCES}" -vv"""

# 1.09  run_wflow — run the Wflow.jl model on historical forcing
rule run_wflow:
    message: rule_banner("1.09", "run_wflow")
    input:
        forcing_path = f"{project_dir}/climate_historical/wflow_data/inmaps_historical.nc"
    output:
        csv_path = f"{basin_dir}/run_default/output.csv"
    params:
        toml_path = f"{basin_dir}/wflow_sbm.toml"
    log:
        f"{project_dir}/logs/1.09_run_wflow.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/1.09_run_wflow.tsv",
    shell:
        """python -u "{run_logged}" "{log}" -- julia +1.11.7 --project=. --threads 4 -e "using Wflow; Wflow.run()" "{params.toml_path}" """

# 1.10  extract_climate_grid_wf1 — extract raw gridded climate for the wf1
# climate plots (P3-2a): the bbox comes from staticmaps.nc (the declared
# rule-1.03 producer edge, design arch-1), the grid is catalog-native, and the
# output path is wf1-owned — distinct from both the wf3 keyed store
# (climate_historical/<key>/) and the wf1 forcing (wflow_data/). On
# chirps/chirps_global the extraction's orography sidecar is a declared rule
# output with a stable, clim_source-independent filename (design ext2-1); the
# branch is resolved at DAG-parse time from clim_historical, so there are no
# dynamic outputs.
_wf1_raw_dir = f"{project_dir}/climate_historical/wf1_raw"
_wf1_raw_outputs = {"climate_nc": f"{_wf1_raw_dir}/extract_historical.nc"}
if clim_source in ("chirps", "chirps_global"):
    _wf1_raw_outputs["oro_nc"] = f"{_wf1_raw_dir}/orography.nc"

rule extract_climate_grid_wf1:
    message: rule_banner("1.10", "extract_climate_grid_wf1")
    input:
        basin_nc = ancient(f"{basin_dir}/staticmaps.nc"),
    params:
        data_sources = DATA_SOURCES,
        clim_source = clim_source,
        starttime = hist_starttime,
        endtime = hist_endtime,
    output:
        **_wf1_raw_outputs,
    log:
        f"{project_dir}/logs/1.10_extract_climate_grid_wf1.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/1.10_extract_climate_grid_wf1.tsv",
    script:
        "blueearth_cst/model/extract_climate_wf1.py"

# 1.11  plot_results — analyse + plot the wflow run (parallel leaf with 1.12/1.13)
rule plot_results:
   message: rule_banner("1.11", "plot_results")
   input:
       csv_path = f"{basin_dir}/run_default/output.csv",
       # forcing input drives the climate plots (ADR 0002); declared so the DAG
       # dependency is explicit even though the script reads it via the model.
       forcing_path = f"{project_dir}/climate_historical/wflow_data/inmaps_historical.nc",
       script = "blueearth_cst/model/plot_results.py"
   output:
       output_png = f"{project_dir}/plots/wflow_model_performance/hydro_wflow_1.png",
   params:
       project_dir = f"{project_dir}",
       observations_file = observations_timeseries,
       gauges_output_path = output_locations,
   log:
       f"{project_dir}/logs/1.11_plot_results.log",
   benchmark:
       f"{project_dir}/benchmarks/_parts/1.11_plot_results.tsv",
   script: "blueearth_cst/model/plot_results.py"

# 1.12  plot_map — plot basin, rivers, gauges and DEM on a map (parallel leaf)
rule plot_map:
    message: rule_banner("1.12", "plot_map")
    input:
        gauges_path = f"{basin_dir}/staticgeoms/outlets.geojson"
    output:
        output_map_png = f"{project_dir}/plots/wflow_model_performance/basin_area.png",
    params:
        project_dir = f"{project_dir}",
        output_locations = output_locations,
    log:
        f"{project_dir}/logs/1.12_plot_map.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/1.12_plot_map.tsv",
    script: "blueearth_cst/shared/plot_map.py"

# 1.13  plot_forcing — plot the forcing on a map (parallel leaf)
rule plot_forcing:
    message: rule_banner("1.13", "plot_forcing")
    input:
        forcing_path = f"{project_dir}/climate_historical/wflow_data/inmaps_historical.nc",
    output:
        output_forcing_map = f"{project_dir}/plots/wflow_model_performance/precip.png",
    params:
        project_dir = f"{project_dir}",
        gauges_path = f"{basin_dir}/staticgeoms/outlets.geojson"
    log:
        f"{project_dir}/logs/1.13_plot_forcing.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/1.13_plot_forcing.tsv",
    script: "blueearth_cst/model/plot_map_forcing.py"

# --- benchmark gather ---------------------------------------------------------
# Per-rule benchmarks land under benchmarks/_parts/. This runs once, after the
# terminal outputs (so all WF1 rules ran), and merges the WF1 parts into one
# benchmarks/wf1_benchmarks.tsv (rule column + TOTAL row), fresh each run.
rule gather_benchmarks:
    message: rule_banner("1.14", "gather_benchmarks")
    input:
        f"{project_dir}/plots/wflow_model_performance/hydro_wflow_1.png",
        f"{project_dir}/plots/wflow_model_performance/basin_area.png",
        f"{project_dir}/plots/wflow_model_performance/precip.png",
        f"{basin_dir}/staticgeoms/outlet_index.csv",
    output:
        f"{project_dir}/benchmarks/wf1_benchmarks.md",
    params:
        parts_dir = f"{project_dir}/benchmarks/_parts",
        workflow_num = 1,
    script: "blueearth_cst/shared/merge_benchmarks.py"
