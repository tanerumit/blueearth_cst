import itertools
import sys
from pathlib import Path

# Shared helpers live in blueearth_cst/; make them importable regardless of the working
# directory by prepending this Snakefile's own directory to sys.path.
# See dev/r03/model-builder-design.md §3.
sys.path.insert(0, str(Path(workflow.basedir)))
from blueearth_cst.shared.snake_utils import get_config, patch_psutil_windows_benchmark, rule_banner

# Windows: make Snakemake's benchmark memory/IO/CPU metrics work (else all NA).
patch_psutil_windows_benchmark()

# read path of the config file (Snakemake records it from --configfile) so
# downstream R scripts can be handed the same path. Forwarding config_path is
# a repo convention.
config_path = workflow.configfiles[0]

# R01 schema
project_cfg = config["project"]
my_cfg = config["workflows"]["climate_projections"]

project_dir = get_config(project_cfg, "project_dir", optional=False)
DATA_SOURCES = get_config(project_cfg, "data_sources_climate", optional=False)

clim_project = get_config(my_cfg, "clim_project", optional=False)
models = get_config(my_cfg, "models", optional=False)
scenarios = get_config(my_cfg, "scenarios", optional=False)
members = get_config(my_cfg, "members", optional=False)
variables = get_config(my_cfg, "variables", optional=False)

start_month_hyd_year = get_config(my_cfg, "start_month_hyd_year", "Jan")
time_horizon_hist = get_config(my_cfg, "historical_year_range", optional=False)
future_horizons = get_config(my_cfg, "future_horizons", optional=False)

save_grids = get_config(my_cfg, "save_grids", False)

basin_dir = f"{project_dir}/hydrology_model"
clim_project_dir = f"{project_dir}/climate_projections/{clim_project}"

### Dictionary elements from the config based on wildcards
def get_horizon(wildcards):
    return config["workflows"]["climate_projections"]["future_horizons"][wildcards.horizon]

# Rule numbering (comment headers + log/benchmark filenames) uses `W.NN` =
# workflow.step in DEFINITION order — a reference aid ("Rule 2.4" = monthly_change),
# not execution order (the DAG fans out over {model}/{scenario}/{horizon}).
# Convention: dev/conventions/naming.md.

# 2.00  all — target aggregator: change-factor summaries + projection plots
rule all:
    input:
        (clim_project_dir + "/annual_change_scalar_stats_summary.nc"),
        (clim_project_dir + "/annual_change_scalar_stats_summary.csv"),
        (clim_project_dir + "/annual_change_scalar_stats_summary_mean.csv"),
        stats_change_plt = (clim_project_dir + "/plots/projected_climate_statistics.png"),
        precip_plt = (clim_project_dir + "/plots/precipitation_anomaly_projections_abs.png"),
        temp_plt = (clim_project_dir + "/plots/temperature_anomaly_projections_abs.png"),
        snake_config = f"{project_dir}/config/snake_config_climate_projections.yml",
        # one merged log per fan-out rule (gathered from the per-model _parts logs)
        stats_hist_log = f"{project_dir}/logs/2.02_monthly_stats_hist.log",
        stats_fut_log = f"{project_dir}/logs/2.03_monthly_stats_fut.log",
        change_log = f"{project_dir}/logs/2.04_monthly_change.log",
        benchmarks = f"{project_dir}/benchmarks/wf2_benchmarks.md",

# Retained as stale insurance pending removal task; dry-run on the current pinned
# Snakemake shows this directive constrains nothing on the tests fixture and a
# reduced config (see dev/r04/climate-projections-design.md §3). Removal deferred
# to a task that first encodes the ambiguity-sensitive config shapes as regression tests.
ruleorder: monthly_stats_hist > monthly_stats_fut > monthly_change > monthly_change_scalar_merge

# 2.01  copy_config — copy snake config into project_dir/config
rule copy_config:
    message: rule_banner("2.01", "copy_config")
    input:
        config_snake = config_path,
    params:
        data_catalogs = DATA_SOURCES,
        workflow_name = "climate_projections",
    output:
        config_snake_out = f"{project_dir}/config/snake_config_climate_projections.yml",
    script:
        "blueearth_cst/model/copy_config_files.py"

# 2.02  monthly_stats_hist — mean monthly stats for the historical period, per
# {model} (grid to netcdf + grid-averaged monthly time series).
rule monthly_stats_hist:
    message: rule_banner("2.02", "monthly_stats_hist")
    input:
        region_path = ancient(f"{basin_dir}/staticgeoms/region.geojson"),
    output:
        #stats_nc_hist = (clim_project_dir + "/historical_stats_{model}.nc"),
        stats_time_nc_hist = temp(clim_project_dir + "/historical_stats_time_{model}.nc"),
    params:
        catalog_path = DATA_SOURCES,
        project_dir = f"{project_dir}",
        name_scenario = "historical",
        name_members = members,
        name_model = "{model}",
        name_clim_project = clim_project,
        variables = variables,
        save_grids = save_grids,
    log:
        project_dir + "/logs/_parts/2.02_monthly_stats_hist/{model}.log",
    benchmark:
        project_dir + "/benchmarks/_parts/2.02_monthly_stats_hist/{model}.tsv",
    script: "blueearth_cst/projections/get_stats_climate_proj.py"

# 2.03  monthly_stats_fut — mean monthly stats per {model}_{scenario} (future),
# chained after 2.02 (grid to netcdf + grid-averaged monthly time series).
rule monthly_stats_fut:
    message: rule_banner("2.03", "monthly_stats_fut")
    input:
        region_path = ancient(f"{basin_dir}/staticgeoms/region.geojson"),
        stats_time_nc_hist = (clim_project_dir + "/historical_stats_time_{model}.nc"), #make sure starts with previous job
    output:
        stats_time_nc = temp(clim_project_dir + "/stats_time-{model}_{scenario}.nc"),
    params:
        catalog_path = DATA_SOURCES,
        project_dir = f"{project_dir}",
        name_scenario = "{scenario}",
        name_members = members,
        name_model = "{model}",
        name_clim_project = clim_project,
        variables = variables,
        save_grids = save_grids,
    log:
        project_dir + "/logs/_parts/2.03_monthly_stats_fut/{model}_{scenario}.log",
    benchmark:
        project_dir + "/benchmarks/_parts/2.03_monthly_stats_fut/{model}_{scenario}.tsv",
    script: "blueearth_cst/projections/get_stats_climate_proj.py"

# 2.04  monthly_change — change factors per {model}_{scenario}_{horizon}
rule monthly_change:
    message: rule_banner("2.04", "monthly_change")
    input:
        stats_time_nc_hist = ancient(clim_project_dir + "/historical_stats_time_{model}.nc"),
        stats_time_nc = ancient(clim_project_dir + "/stats_time-{model}_{scenario}.nc"),
    output:
        stats_nc_change = temp(clim_project_dir + "/annual_change_scalar_stats-{model}_{scenario}_{horizon}.nc"),
    params:
        clim_project_dir = f"{clim_project_dir}",
        start_month_hyd_year = start_month_hyd_year, 
        name_model = "{model}",
        name_scenario = "{scenario}",
        name_horizon = "{horizon}",
        time_horizon_hist = time_horizon_hist,
        time_horizon_fut = get_horizon,
        save_grids = save_grids,
        stats_path_hist = (clim_project_dir + "/historical_stats_{model}.nc"),
        stats_path = (clim_project_dir + "/stats-{model}_{scenario}.nc"),
    log:
        project_dir + "/logs/_parts/2.04_monthly_change/{model}_{scenario}_{horizon}.log",
    benchmark:
        project_dir + "/benchmarks/_parts/2.04_monthly_change/{model}_{scenario}_{horizon}.tsv",
    script: "blueearth_cst/projections/get_change_climate_proj.py"

# 2.05  monthly_change_scalar_merge — merge all change factors into one summary
rule monthly_change_scalar_merge:
    message: rule_banner("2.05", "monthly_change_scalar_merge")
    input:
        stats_nc_change = ancient(expand((clim_project_dir + "/annual_change_scalar_stats-{model}_{scenario}_{horizon}.nc"), model = models, scenario = scenarios, horizon = future_horizons)),
    output:
        stats_change_summary = (clim_project_dir + "/annual_change_scalar_stats_summary.nc"),
        stats_change_summary_csv = (clim_project_dir + "/annual_change_scalar_stats_summary.csv"),
        stats_change_summary_csv_mean = (clim_project_dir + "/annual_change_scalar_stats_summary_mean.csv"),
        stats_change_plt = (clim_project_dir + "/plots/projected_climate_statistics.png"),
    params:
        clim_project_dir = f"{clim_project_dir}",
        horizons = future_horizons,
    log:
        f"{project_dir}/logs/2.05_monthly_change_scalar_merge.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/2.05_monthly_change_scalar_merge.tsv",
    script: "blueearth_cst/projections/get_change_climate_proj_summary.py"

# 2.06  plot_climate_proj_timeseries — plot projected anomaly time series
rule plot_climate_proj_timeseries:
    message: rule_banner("2.06", "plot_climate_proj_timeseries")
    input:
        stats_change_summary = (clim_project_dir + "/annual_change_scalar_stats_summary.nc"),
        stats_time_nc_hist =[(clim_project_dir + f"/historical_stats_time_{mod}.nc") for mod in models],
        stats_time_nc = expand((clim_project_dir + "/stats_time-{model}_{scenario}.nc"), model = models, scenario = scenarios),
    params:
        clim_project_dir = f"{clim_project_dir}",
        scenarios = scenarios,
        horizons = future_horizons,
        save_grids = save_grids,
        change_grids = [(clim_project_dir + f"/monthly_change_mean_grid-{mod}_{sc}_{hz}.nc") for mod,sc,hz in list(itertools.product(models,scenarios,future_horizons))],
    output:
        precip_plt = (clim_project_dir + "/plots/precipitation_anomaly_projections_abs.png"),
        temp_plt = (clim_project_dir + "/plots/temperature_anomaly_projections_abs.png"),
        timeseries_csv = (clim_project_dir + "/gcm_timeseries.nc"),
    log:
        f"{project_dir}/logs/2.06_plot_climate_proj_timeseries.log",
    benchmark:
        f"{project_dir}/benchmarks/_parts/2.06_plot_climate_proj_timeseries.tsv",
    script: "blueearth_cst/projections/plot_proj_timeseries.py"

# --- log gather ---------------------------------------------------------------
# 2.02/2.03/2.04 run one job per model (parallel-safe per-model logs under
# logs/_parts/). These gather steps run once per stage, after all that stage's
# jobs, concatenating the per-model parts into a single logs/<rule>.log,
# regenerated fresh each run. Inputs are the stage's .nc outputs (all model jobs
# done); the exact part paths are passed via params so stale parts are excluded.

# gather 2.02 per-model logs -> 2.02_monthly_stats_hist.log
rule gather_stats_hist_logs:
    message: rule_banner("2.07", "gather_stats_hist_logs")
    input:
        expand(clim_project_dir + "/historical_stats_time_{model}.nc", model=models),
    output:
        f"{project_dir}/logs/2.02_monthly_stats_hist.log",
    params:
        parts = expand(
            project_dir + "/logs/_parts/2.02_monthly_stats_hist/{model}.log",
            model=models,
        ),
    script: "blueearth_cst/shared/merge_logs.py"

# gather 2.03 per-model logs -> 2.03_monthly_stats_fut.log
rule gather_stats_fut_logs:
    message: rule_banner("2.08", "gather_stats_fut_logs")
    input:
        expand(
            clim_project_dir + "/stats_time-{model}_{scenario}.nc",
            model=models, scenario=scenarios,
        ),
    output:
        f"{project_dir}/logs/2.03_monthly_stats_fut.log",
    params:
        parts = expand(
            project_dir + "/logs/_parts/2.03_monthly_stats_fut/{model}_{scenario}.log",
            model=models, scenario=scenarios,
        ),
    script: "blueearth_cst/shared/merge_logs.py"

# gather 2.04 per-model logs -> 2.04_monthly_change.log
rule gather_change_logs:
    message: rule_banner("2.09", "gather_change_logs")
    input:
        expand(
            clim_project_dir + "/annual_change_scalar_stats-{model}_{scenario}_{horizon}.nc",
            model=models, scenario=scenarios, horizon=future_horizons,
        ),
    output:
        f"{project_dir}/logs/2.04_monthly_change.log",
    params:
        parts = expand(
            project_dir + "/logs/_parts/2.04_monthly_change/{model}_{scenario}_{horizon}.log",
            model=models, scenario=scenarios, horizon=future_horizons,
        ),
    script: "blueearth_cst/shared/merge_logs.py"

# --- benchmark gather ---------------------------------------------------------
# Merge WF2's per-rule benchmark parts (benchmarks/_parts/2.*) into one
# benchmarks/wf2_benchmarks.tsv (rule column + TOTAL row) once the summary +
# plots are built (all WF2 rules ran).
rule gather_benchmarks:
    message: rule_banner("2.10", "gather_benchmarks")
    input:
        (clim_project_dir + "/annual_change_scalar_stats_summary.nc"),
        (clim_project_dir + "/plots/projected_climate_statistics.png"),
        (clim_project_dir + "/plots/precipitation_anomaly_projections_abs.png"),
    output:
        f"{project_dir}/benchmarks/wf2_benchmarks.md",
    params:
        parts_dir = f"{project_dir}/benchmarks/_parts",
        workflow_num = 2,
    script: "blueearth_cst/shared/merge_benchmarks.py"
